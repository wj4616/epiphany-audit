{
  "version": "2.0.3",
  "conventions": {
    "resolved_flags_propagation": "resolved_flags is captured by N01 from CLI args and included in the compound project_model. Because project_model flows to all downstream nodes via data edges (E00a, E01, E03, etc.), resolved_flags is implicitly available to every node without being declared as a discrete input in graph.json. Modules that consume resolved_flags SHOULD list it in their ## Inputs section for clarity, even though the graph layer does not model it as a separate edge payload. The authoritative declaration is in N01 outputs (project_model contains resolved_flags) plus the convention stated here.",
    "input_type_propagation": "input_type is produced exclusively by N00b InputTypeDetector. It is NOT a direct N01 output (N01 emits project_model with input_type=null). After N00b classifies, the value is written back to N01's project_model via feedback edge E00d, and N01 enriches the model with type-specific fields (heading_hierarchy, phase_count, skill_name, etc.) before downstream consumption. From E01 onward, project_model carries input_type. Edge E00e from N00b → N02 is a CLARITY/CONFIRMATION channel — it documents that N02 conceptually depends on N00b's classification, even though the same payload also reaches N02 via E01 after N01 enrichment. Removing E00e would not change runtime behavior; it is preserved for graph readability.",
    "spawn_cap": "Under --deep, the dimension analyzer batch (N04..N09) shares ONE subagent slot — not one slot per analyzer. Total subagent ceiling: ≤3 under --deep (dim-batch:1 + N14-PassB:1 + N21-rerun:1); ≤4 under --deep + --improve (+ N25-phase2:1). SKILL.md §14 '≤3 spawn budget (≤4 with --improve)' refers to this TOTAL ceiling, not just the analyzer batch. Implementations MUST enforce the total ceiling; emitting more than one concurrent subagent across N04..N09 is a contract violation regardless.",
    "halt_condition_naming": "All halt IDs MUST start with 'halt-'. Pattern: halt-<timing>-<condition> where timing is: 'on' (immediate/reactive to a specific event), 'pre' (before a phase or pipeline entry), 'mid' (during active processing), or a surface classifier ('suspicious', 'ambiguous', 'no'). Regex to match all valid forms: ^halt-(on|pre|mid|suspicious|ambiguous|no)-. Examples: halt-on-flag-conflict, halt-pre-audit, halt-mid-fix-on-perfix-cap-hit, halt-suspicious-target, halt-ambiguous-target.",
    "plugin_path_resolution": "Bundled dimension plugins live at <skill_dir>/dimensions/*.md, where <skill_dir> resolves at runtime to the directory containing this graph.json (i.e., ~/.claude/skills/epiphany-audit-v2/). Implementations MUST use file-relative resolution (e.g., __file__-relative in Python) and MUST NOT hardcode the v1 path ~/.claude/skills/epiphany-audit/."
  },
  "nodes": [
    {
      "id": "N01",
      "name": "ContextIntake",
      "type": "ingest",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["cli_args", "cwd", "env"],
      "outputs": ["project_model", "resolved_flags"],
      "outputs_note": "project_model.input_type is initially null; it is set by N00b via feedback edge E00d, after which N01 enriches project_model with type-specific fields. See conventions.input_type_propagation.",
      "aggregation_policy": "n/a",
      "halt_conditions": [
        "halt-pre-audit", "halt-suspicious-target",
        "halt-ambiguous-target", "halt-on-flag-conflict",
        "halt-on-flag-rejection", "halt-no-source-detected",
        "halt-on-target-conflict"
      ]
    },
    {
      "id": "N00a",
      "name": "AuditabilityPrerequisiteGate",
      "type": "classifier",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model"],
      "outputs": ["prerequisite_gate_result"],
      "aggregation_policy": "n/a",
      "halt_conditions": []
    },
    {
      "id": "N00b",
      "name": "InputTypeDetector",
      "type": "classifier",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model"],
      "outputs": ["detector_confidence_trace", "input_type"],
      "aggregation_policy": "n/a",
      "halt_conditions": []
    },
    {
      "id": "N02",
      "name": "RelevanceRouter",
      "type": "router",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "dimension_plugins", "input_type"],
      "outputs": ["dimension_activation_map", "plugin_registry", "file_subset"],
      "aggregation_policy": "n/a",
      "halt_conditions": ["halt-on-floor-plugin-missing"]
    },
    {
      "id": "N03",
      "name": "BlindspotFinder",
      "type": "meta-analyzer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "dimension_activation_map"],
      "outputs": ["updated_dimension_activation_map", "gap_dimensions_offered", "gap_dimensions_auto_added"],
      "aggregation_policy": "n/a",
      "halt_conditions": ["halt-on-user-abort"]
    },
    {
      "id": "N04",
      "name": "DimensionAnalyzer.CORRECTNESS",
      "type": "analyzer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "file_subset"],
      "outputs": ["raw_findings"],
      "aggregation_policy": "participant in BACKTRACK via N10",
      "halt_conditions": []
    },
    {
      "id": "N05",
      "name": "DimensionAnalyzer.ARCHITECTURE",
      "type": "analyzer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "file_subset"],
      "outputs": ["raw_findings"],
      "aggregation_policy": "participant in BACKTRACK via N10",
      "halt_conditions": []
    },
    {
      "id": "N06",
      "name": "DimensionAnalyzer.PERFORMANCE",
      "type": "analyzer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "file_subset"],
      "outputs": ["raw_findings"],
      "aggregation_policy": "participant in BACKTRACK via N10",
      "halt_conditions": []
    },
    {
      "id": "N07",
      "name": "DimensionAnalyzer.SECURITY",
      "type": "analyzer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "file_subset"],
      "outputs": ["raw_findings"],
      "aggregation_policy": "participant in BACKTRACK via N10",
      "halt_conditions": []
    },
    {
      "id": "N08",
      "name": "DimensionAnalyzer.MAINTAINABILITY",
      "type": "analyzer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "file_subset"],
      "outputs": ["raw_findings"],
      "aggregation_policy": "participant in BACKTRACK via N10",
      "halt_conditions": []
    },
    {
      "id": "N09",
      "name": "DimensionAnalyzer.<X>",
      "type": "analyzer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["project_model", "file_subset", "plugin_manifest"],
      "outputs": ["raw_findings"],
      "aggregation_policy": "participant in BACKTRACK via N10",
      "halt_conditions": [],
      "spawn_policy": "plugin-instantiated at runtime; concrete instances get IDs N09.a11y, N09.iac-drift, etc."
    },
    {
      "id": "N10",
      "name": "FalsePositiveVerifier",
      "type": "verifier",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["raw_findings from N04..N09", "project_model", "resolved_flags"],
      "outputs": ["verified_findings", "location_verification_cache", "falsifiability_survival_log"],
      "aggregation_policy": "BACKTRACKING owner (single re-emit cap on N04..N09); AGGREGATION owner of falsifiability_survival_log (v2.0.1)",
      "halt_conditions": [],
      "notes": "v2.0.1: falsifiability counter-argument generation (severity ≥ MEDIUM) moved here from N13 — N10 already has source-file Read access for location verification. N13 only renders the resulting falsifiability block."
    },
    {
      "id": "N11",
      "name": "FindingsAggregator",
      "type": "aggregator",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["verified_findings from N10"],
      "outputs": ["deduplicated_findings"],
      "aggregation_policy": "AGGREGATION owner (audit side)",
      "halt_conditions": []
    },
    {
      "id": "N12",
      "name": "Prioritizer",
      "type": "scorer",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["deduplicated_findings"],
      "outputs": ["prioritized_findings", "punch_list"],
      "aggregation_policy": "n/a",
      "halt_conditions": []
    },
    {
      "id": "N13",
      "name": "ReportFormatter",
      "type": "formatter",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["prioritized_findings", "punch_list", "project_model"],
      "outputs": ["formatted_report_markdown"],
      "aggregation_policy": "n/a",
      "halt_conditions": [],
      "notes": "v2.x: emits medical-diagnostic tetrad on every finding; runs falsifiability-first creativity check and multi-trial creativity tournament"
    },
    {
      "id": "N14",
      "name": "Q-GATE",
      "type": "verifier",
      "mode": "inline (Pass A) + conditional subagent (Pass B)",
      "active_in": "audit",
      "inputs": ["formatted_report_markdown", "location_verification_cache", "detector_confidence_trace", "section_selector_confidence", "falsifiability_survival_log"],
      "outputs": ["q_gate_result", "validated_report", "tetrad_completeness", "two_axis_scores", "two_axis_scores_overridden_by_user"],
      "aggregation_policy": "adversarial self-review",
      "halt_conditions": ["halt-on-q-gate-failure"],
      "spawn_policy": "Pass B spawns when: >=5 findings OR any CRITICAL/HIGH severity OR --deep flag",
      "notes": "v2.x: Pass A check #2 verifies tetrad-completeness; Pass A check #8 enforces two-axis hard gate (creativity >=7, functional_correctness >=7); Pass A check #9 enforces frontmatter-trace coherence. Halt subreasons: pass-a, pass-b, pass-b-exec-error, two-axis-below-threshold, frontmatter-trace-incoherence."
    },
    {
      "id": "N15",
      "name": "SaveHandler",
      "type": "io",
      "mode": "inline",
      "active_in": "audit",
      "inputs": ["validated_report", "project_model"],
      "outputs": ["save_decision", "saved_report_path", "report_id"],
      "aggregation_policy": "n/a",
      "halt_conditions": [],
      "notes": "v2.x: emits self-audit traces; resolves slugs per input type; computes and stores project_content_sha256"
    },
    {
      "id": "N16",
      "name": "FixTriage",
      "type": "validator",
      "mode": "inline",
      "active_in": "fix",
      "inputs": ["audit_report_path", "resolved_flags", "recovery_manifest_if_resume"],
      "outputs": ["triage_result", "fix_groups", "topo_sorted_order"],
      "aggregation_policy": "AGGREGATION (file-grouping) + CONDITIONAL ROUTING owner",
      "halt_conditions": [
        "halt-pre-fix-on-validator-failure", "halt-on-empty-or-unfixable-report",
        "halt-on-conflicting-fixes", "halt-on-files-outside-tree",
        "halt-on-invalid-finding-id", "halt-on-resume-tree-divergence",
        "halt-on-stale-source-report", "halt-on-mismatched-version",
        "halt-on-user-abort", "halt-on-ambiguous-fix-report",
        "halt-on-unresolvable-fix-report", "halt-on-no-audit-report",
        "halt-on-recovery-conflict"
      ]
    },
    {
      "id": "N17",
      "name": "FixPlanner",
      "type": "planner",
      "mode": "inline",
      "active_in": "fix",
      "inputs": ["triage_result", "fix_groups"],
      "outputs": ["fix_plan_doc", "user_approvals"],
      "aggregation_policy": "n/a",
      "halt_conditions": ["halt-on-user-abort"]
    },
    {
      "id": "N18",
      "name": "PreFlight",
      "type": "preflight",
      "mode": "inline",
      "active_in": "fix",
      "inputs": ["fix_plan_doc", "project_model"],
      "outputs": ["baseline_metrics", "branch_name"],
      "aggregation_policy": "n/a",
      "halt_conditions": [
        "halt-on-baseline-failure", "halt-on-test-cmd-unknown",
        "halt-on-git-state-incompatible"
      ]
    },
    {
      "id": "N19",
      "name": "FixApplier",
      "type": "actuator",
      "mode": "inline (write-serial)",
      "active_in": "fix",
      "inputs": ["fix_groups", "user_approvals", "baseline_metrics", "branch_name"],
      "outputs": ["per_fix_outcomes", "recovery_manifest_updates"],
      "aggregation_policy": "n/a",
      "halt_conditions": ["halt-mid-fix-on-perfix-cap-hit"]
    },
    {
      "id": "N20",
      "name": "PerFixVerifier",
      "type": "verifier",
      "mode": "inline",
      "active_in": "fix",
      "inputs": ["changed_files", "baseline_metrics", "test_cmd", "input_type"],
      "outputs": ["verify_result", "failure_context"],
      "aggregation_policy": "emits fail-signal; routing is E_repair's responsibility",
      "halt_conditions": []
    },
    {
      "id": "N21",
      "name": "RegressionBattery",
      "type": "verifier",
      "mode": "inline (battery) + conditional subagent (audit-rerun under --deep)",
      "active_in": "both",
      "inputs": ["per_fix_outcomes", "baseline_metrics", "applied_tier_max"],
      "outputs": ["battery_result", "audit_rerun_delta"],
      "aggregation_policy": "adversarial-via-rerun",
      "halt_conditions": [
        "halt-on-scope-creep", "halt-mid-fix-on-induced-regression-cap-hit"
      ]
    },
    {
      "id": "N22",
      "name": "RollbackHandler",
      "type": "recovery",
      "mode": "inline",
      "active_in": "fix",
      "inputs": ["e_repair_cap_hit_signal_or_e_finalize_signal", "fix_report_id_on_finalize"],
      "outputs": ["recovery_manifest_finalized", "archive_path"],
      "aggregation_policy": "n/a",
      "halt_conditions": []
    },
    {
      "id": "N23",
      "name": "FixReporter",
      "type": "formatter",
      "mode": "inline",
      "active_in": "fix",
      "inputs": ["per_fix_outcomes", "baseline_metrics", "audit_rerun_delta"],
      "outputs": ["fix_report_markdown", "fix_report_id"],
      "aggregation_policy": "AGGREGATION (per-fix outcomes)",
      "halt_conditions": []
    },
    {
      "id": "N24",
      "name": "ImprovementContextualizer",
      "type": "analyzer",
      "mode": "inline",
      "active_in": "improve",
      "inputs": ["project_model from N01", "validated_report from N14"],
      "outputs": ["improvement_context"],
      "aggregation_policy": "n/a",
      "halt_conditions": []
    },
    {
      "id": "N25",
      "name": "ImprovementBrainstormer",
      "type": "analyzer",
      "mode": "inline (phase 1) + optional subagent (phase 2 when --deep and >=8 candidates)",
      "active_in": "improve",
      "inputs": ["improvement_context"],
      "outputs": ["improvement_candidates"],
      "aggregation_policy": "participant in AGGREGATION via N26",
      "halt_conditions": [],
      "spawn_policy": "0 or 1 spawn: phase 2 only when --deep AND >=8 raw candidates from phase 1"
    },
    {
      "id": "N26",
      "name": "OverEngineeringFilter",
      "type": "filter",
      "mode": "inline",
      "active_in": "improve",
      "inputs": ["improvement_candidates"],
      "outputs": ["survivors", "discarded_improvements"],
      "aggregation_policy": "AGGREGATION (candidate filtering + categorization)",
      "halt_conditions": []
    },
    {
      "id": "N27",
      "name": "ImprovementReporter",
      "type": "formatter",
      "mode": "inline",
      "active_in": "improve",
      "inputs": ["survivors", "discarded_improvements", "improvement_context"],
      "outputs": ["improvement_report_markdown"],
      "aggregation_policy": "n/a",
      "halt_conditions": []
    }
  ],
  "edges": [
    {"id": "E00a",         "source": "N01", "target": "N00a",             "channel": "data",        "cardinality": "1:1",  "activation": "always; N01 produces project_model → N00a prerequisite gate"},
    {"id": "E00b",         "source": "N00a", "target": "N00b",            "channel": "data",        "cardinality": "1:1",  "activation": "on PASS; prerequisite gate satisfied → input type detection"},
    {"id": "E00c",         "source": "N00a", "target": "user",            "channel": "control",     "cardinality": "1:1",  "activation": "on FAIL; non-auditability verdict emitted to user"},
    {"id": "E00d",         "source": "N00b", "target": "N01",             "channel": "feedback",    "cardinality": "1:1",  "activation": "always; input_type set on N01 project_model via feedback edge"},
    {"id": "E00e",         "source": "N00b", "target": "N02",             "channel": "data",        "cardinality": "1:1",  "activation": "always (post-E00d); classified input_type → N02 relevance router"},
    {"id": "E01",          "source": "N01", "target": "N02",              "channel": "data",        "cardinality": "1:1",  "activation": "always"},
    {"id": "E02",          "source": "N02", "target": "N03",              "channel": "data",        "cardinality": "1:1",  "activation": "always"},
    {"id": "E03",          "source": "N03", "target": ["N04","N05","N06","N07","N08","N09"], "channel": "control", "cardinality": "1:N",  "activation": "per updated activation map post-BFIND; floor (CORRECTNESS, MAINTAINABILITY) always emits"},
    {"id": "E04",          "source": "N03", "target": "user",             "channel": "interactive", "cardinality": "1:1",  "activation": "only under --deep; default mode auto-adds HIGH-confidence gaps without prompting"},
    {"id": "E05",          "source": ["N04","N05","N06","N07","N08","N09"], "target": "N10", "channel": "data", "cardinality": "fan-in", "activation": "always"},
    {"id": "E06",          "source": "N10", "target": ["N04","N05","N06","N07","N08","N09"], "channel": "feedback", "cardinality": "refinement", "activation": "BACKTRACKING — single-attempt cap on re-emit"},
    {"id": "E07",          "source": "N10", "target": "N11",             "channel": "data",        "cardinality": "1:1",  "activation": "always"},
    {"id": "E08",          "source": "N11", "target": "N12",             "channel": "data",        "cardinality": "1:1",  "activation": "always"},
    {"id": "E09",          "source": "N12", "target": "N13",             "channel": "data",        "cardinality": "1:1",  "activation": "always"},
    {"id": "E10",          "source": "N13", "target": "N14",             "channel": "control",     "cardinality": "1:1",  "activation": "always"},
    {"id": "E11",          "source": "N14", "target": "N15",             "channel": "data",        "cardinality": "1:1",  "activation": "Pass A succeeds AND (Pass B succeeds OR skipped-low-volume); Pass B exec-error -> halt"},
    {"id": "E12",          "source": "N15", "target": "user",            "channel": "interactive", "cardinality": "1:1",  "activation": "save? prompt after N15 save-decision resolves"},
    {"id": "E13a",         "source": "N16", "target": "N17",              "channel": "data",        "cardinality": "1:1",  "activation": "fix pipeline entry from --fix or post-E21 fix-offer consent"},
    {"id": "E13b",         "source": "N17", "target": "N18",              "channel": "data",        "cardinality": "1:1",  "activation": "always within fix pipeline"},
    {"id": "E13c",         "source": "N18", "target": "N19",              "channel": "data",        "cardinality": "1:1",  "activation": "always within fix pipeline"},
    {"id": "E13d",         "source": "N19", "target": "N20",              "channel": "data",        "cardinality": "1:1",  "activation": "on per-fix-group complete"},
    {"id": "E13e",         "source": "N20", "target": "N21",              "channel": "data",        "cardinality": "1:1",  "activation": "on PerFixVerify success -> regression battery"},
    {"id": "E13f",         "source": "N21", "target": "N23",              "channel": "data",        "cardinality": "1:1",  "activation": "on battery complete"},
    {"id": "E14",          "source": "E_repair cap-hit", "target": "N22", "channel": "control",   "cardinality": "1:1",  "activation": "E_repair 3rd invocation (cap-hit) -> N22 finalizes recovery manifest for failed fix-group"},
    {"id": "E_halt_partial","source": "halt-mid-fix-*", "target": ["N23","user"], "channel": "control", "cardinality": "1:1", "activation": "perfix-cap-hit or induced-regression-cap-hit AND every remaining group blocked"},
    {"id": "E15",          "source": "N20", "target": "N19",            "channel": "feedback",    "cardinality": "1:1",  "activation": "on PerFixVerify success -> next fix-group"},
    {"id": "E_repair",     "source": ["N20 fail","N21 fail"], "target": ["N17","N19"], "channel": "feedback", "cardinality": "1:1", "activation": "bounded: 1st->N19 retry; 2nd->N17 replan; 3rd->cap-hit"},
    {"id": "E_rerun_fail", "source": "N21 audit-rerun induced-regression", "target": "N16", "channel": "feedback", "cardinality": "1:1 batched", "activation": "re-triage with regression context; only for new findings in files touched by fixes"},
    {"id": "E_diffscope",  "source": "N21 diff-scope-check fail", "target": "halt", "channel": "control", "cardinality": "1:0", "activation": "scope-creep detected; do NOT auto-revert"},
    {"id": "E_finalize",   "source": "N23", "target": "N22",            "channel": "control",     "cardinality": "1:1",  "activation": "planned termination: N23 writes report -> E_finalize -> N22 reads fix_report_id + archives manifest -> E_complete"},
    {"id": "E_complete",   "source": "N22", "target": "user",           "channel": "data",        "cardinality": "1:1",  "activation": "terminal; fires after N22 finalizes + archives manifest"},
    {"id": "E16",          "source": "N15", "target": "N24",            "channel": "control",     "cardinality": "1:1",  "activation": "--improve only; fires after save prompt resolves; does NOT fire in --fix mode"},
    {"id": "E17",          "source": "N24", "target": "N25",            "channel": "data",        "cardinality": "1:1",  "activation": "always within --improve subpipeline"},
    {"id": "E18",          "source": "N25", "target": "N26",            "channel": "data",        "cardinality": "1:1",  "activation": "always within --improve subpipeline"},
    {"id": "E19",          "source": "N26", "target": "N27",            "channel": "data",        "cardinality": "1:1",  "activation": "always within --improve subpipeline"},
    {"id": "E20",          "source": "N27", "target": "user",           "channel": "data",        "cardinality": "1:1",  "activation": "terminal for --improve subpipeline; improvement report written unconditionally; E21 fires AFTER E20 resolves in no-flag mode"},
    {"id": "E21",          "source": ["N27","N15"], "target": "user",   "channel": "interactive", "cardinality": "1:1",  "activation": "fix? offer; in --improve no-flag mode fires after E20; in non-improve no-flag mode fires after E12"},
    {"id": "E_trace_detector", "source": "N00b", "target": "N14",       "channel": "data",        "cardinality": "1:1",  "activation": "always; v2.0.2 — N00b's detector_confidence_trace flows to N14 Pass A check #9 (frontmatter coherence). Side-channel to the main N13→N14 data path."},
    {"id": "E_trace_section",  "source": "N02",  "target": "N14",       "channel": "data",        "cardinality": "1:1",  "activation": "always; v2.0.2 — N02's section_selector_confidence flows to N14 Pass A check #9 (frontmatter coherence). Side-channel to the main N13→N14 data path."},
    {"id": "E_log_thread",     "source": "N10",  "target": "N14",       "channel": "data",        "cardinality": "1:1",  "activation": "always; v2.0.2 — N10's falsifiability_survival_log flows directly to N14 (bypass N11/N12/N13 which do not carry it). Replaces the broken 'passed through N13' path documented in v2.0.1."}
  ]
}
